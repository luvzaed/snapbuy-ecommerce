generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  price       Float
  image       String
  description String
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     String
}